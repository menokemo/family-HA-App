<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#C62E44"
    android:padding="36dp">

    <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

    <TextView
        android:id="@+id/shieldText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🛡"
        android:textSize="64sp"
        android:layout_marginBottom="20dp" />

    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="تم تشغيل الإنذار"
        android:textColor="#FFFFFF"
        android:textSize="27sp"
        android:textStyle="bold"
        android:letterSpacing="0.01"
        android:layout_marginBottom="18dp" />

    <TextView
        android:id="@+id/reasonText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingHorizontal="18dp"
        android:paddingVertical="10dp"
        android:background="@drawable/reason_card_bg"
        android:visibility="gone" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="#FFFFFF"
        android:alpha="0.8"
        android:textSize="14sp"
        android:layout_marginTop="14dp" />

    <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

    <FrameLayout
        android:layout_width="290dp"
        android:layout_height="68dp"
        android:background="@drawable/slider_track_bg"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="اسحب للتعطيل  ‹ ‹ ‹"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:alpha="0.8" />

        <SeekBar
            android:id="@+id/disarmSlider"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@android:color/transparent"
            android:splitTrack="false"
            android:thumb="@drawable/slider_thumb" />

    </FrameLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Family HA"
        android:textColor="#FFFFFF"
        android:alpha="0.55"
        android:textSize="12sp"
        android:letterSpacing="0.08" />

</LinearLayout>
